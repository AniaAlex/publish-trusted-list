# Pocketbase admin (created on first boot)
PB_ADMIN_EMAIL=admin@wp4trust.local
PB_ADMIN_PASSWORD=change-me-now

# Host port to bind Pocketbase to
PB_PORT=8090

# Go publisher service (the g119612 pipeline behind an HTTP API).
# Used by pb_hooks/publish.pb.js when an operator clicks "Publish".
# Leave as-is for now — the publisher service is built in a later step.
PUBLISHER_URL=http://host.docker.internal:8080
